<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Call Diagnosis™ — by ScaleCo</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Mono:wght@400;500&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg:        #0a0a0a;
    --bg-card:   #111111;
    --bg-input:  #161616;
    --border:    rgba(255,255,255,0.07);
    --border-h:  rgba(255,255,255,0.14);
    --text:      #f0ece4;
    --text-2:    #8a8680;
    --text-3:    #3e3c3a;
    --blue:      #2D5BE3;
    --blue-dim:  rgba(45,91,227,0.12);
    --blue-glow: rgba(45,91,227,0.25);
    --red:       #ff4d4d;
    --red-dim:   rgba(255,77,77,0.1);
    --amber:     #f5a623;
    --amber-dim: rgba(245,166,35,0.1);
    --green:     #3ddc84;
    --green-dim: rgba(61,220,132,0.1);
    --r-md: 10px; --r-lg: 16px;
    --ff-head: 'Bebas Neue', sans-serif;
    --ff-body: 'DM Sans', sans-serif;
    --ff-mono: 'DM Mono', monospace;
  }

  html { scroll-behavior: smooth; }
  body { background: var(--bg); color: var(--text); font-family: var(--ff-body); font-size: 14px; line-height: 1.6; min-height: 100vh; }
  .page { max-width: 860px; margin: 0 auto; padding: 36px 20px 80px; }

  /* HEADER */
  header {
    display: flex; align-items: baseline; gap: 14px;
    margin-bottom: 40px; padding-bottom: 24px;
    border-bottom: 1px solid var(--border);
  }
  .hdr-title { font-family: var(--ff-head); font-size: 26px; letter-spacing: .04em; color: var(--text); line-height: 1; white-space: nowrap; }
  .hdr-by { font-size: 11px; color: rgba(255,255,255,0.25); font-family: var(--ff-mono); letter-spacing: .02em; white-space: nowrap; }
  .hdr-by span { color: var(--blue); }

  /* FORM GATE */
  #gateSection { animation: fadeUp 0.4s ease both; }
  .gate-hero { margin-bottom: 32px; }
  .gate-hero h2 { font-family: var(--ff-head); font-size: 40px; letter-spacing: .02em; line-height: 1.08; margin-bottom: 12px; }
  .gate-hero h2 span { color: var(--blue); }
  .gate-hero p { color: var(--text-2); font-size: 14px; line-height: 1.7; }

  .features-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 8px; margin: 24px 0 32px; }
  .feat { padding: 14px; background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--r-md); }
  .feat-icon { font-size: 16px; margin-bottom: 8px; }
  .feat-title { font-size: 11px; font-weight: 600; color: var(--text); margin-bottom: 4px; }
  .feat-desc { font-size: 11px; color: var(--text-2); line-height: 1.4; }

  .form-group { margin-bottom: 12px; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  label { display: block; font-size: 10px; font-weight: 500; letter-spacing: .08em; text-transform: uppercase; color: var(--text-3); margin-bottom: 5px; font-family: var(--ff-mono); }
  input[type="text"], input[type="email"], select, textarea {
    width: 100%; background: var(--bg-input); border: 1px solid var(--border); border-radius: var(--r-md);
    color: var(--text); font-family: var(--ff-body); font-size: 14px; outline: none; transition: border-color .15s;
  }
  input[type="text"], input[type="email"], select { height: 40px; padding: 0 12px; }
  textarea { padding: 12px; resize: vertical; min-height: 160px; line-height: 1.6; }
  input:focus, select:focus, textarea:focus { border-color: var(--blue); box-shadow: 0 0 0 3px var(--blue-dim); }
  input::placeholder, textarea::placeholder { color: var(--text-3); }
  select option { background: #1a1a1a; }

  .divider { display: flex; align-items: center; gap: 12px; font-size: 10px; color: var(--text-3); letter-spacing: .1em; text-transform: uppercase; font-family: var(--ff-mono); margin: 20px 0 14px; }
  .divider::before, .divider::after { content: ''; flex: 1; height: 1px; background: var(--border); }

  .btn-primary { width: 100%; height: 52px; background: var(--blue); color: #fff; border: none; border-radius: var(--r-md); font-family: var(--ff-head); font-size: 18px; letter-spacing: .06em; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 8px; transition: opacity .15s, transform .1s; margin-top: 20px; box-shadow: 0 0 40px var(--blue-glow); }
  .btn-primary:hover { opacity: .88; }
  .btn-primary:active { transform: scale(.99); }
  .btn-primary:disabled { opacity: .35; cursor: not-allowed; }
  .btn-ghost { background: transparent; border: 1px solid var(--border); color: var(--text-2); border-radius: var(--r-md); padding: 9px 16px; font-family: var(--ff-body); font-size: 13px; cursor: pointer; transition: border-color .15s, color .15s; }
  .btn-ghost:hover { border-color: var(--border-h); color: var(--text); }

  .error-box { display: none; padding: 10px 14px; margin-top: 10px; background: var(--red-dim); border: 1px solid rgba(255,77,77,.2); border-radius: var(--r-md); color: var(--red); font-size: 12px; }
  .error-box.visible { display: block; }

  /* LOADING */
  #loadingSection { display: none; text-align: center; padding: 80px 20px; }
  .loading-ring { width: 44px; height: 44px; margin: 0 auto 24px; border: 2px solid var(--border); border-top-color: var(--blue); border-radius: 50%; animation: spin .8s linear infinite; }
  .loading-title { font-family: var(--ff-head); font-size: 22px; letter-spacing: .04em; margin-bottom: 8px; }
  .loading-msg { color: var(--text-2); font-size: 12px; font-family: var(--ff-mono); }

  /* RESULT */
  #resultSection { display: none; animation: fadeUp .4s ease both; }

  .ctx-exec { display: grid; grid-template-columns: 1fr 1fr; margin-bottom: 12px; background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--r-md); overflow: hidden; }
  .ctx-col { padding: 14px 16px; }
  .ctx-col+.ctx-col { border-left: 1px solid var(--border); }
  .ctx-col-label { font-size: 8px; font-family: var(--ff-mono); color: var(--text-3); letter-spacing: .1em; text-transform: uppercase; margin-bottom: 8px; }
  .ctx-deal-title { font-family: var(--ff-head); font-size: 16px; letter-spacing: .04em; color: var(--text); margin-bottom: 2px; }
  .ctx-deal-sub { font-size: 11px; color: var(--text-2); }
  .ctx-meta-row { display: flex; flex-direction: column; gap: 4px; }
  .ctx-meta-item { font-size: 11px; color: var(--text-2); }
  .ctx-meta-item strong { color: var(--text); }
  .ctx-status { margin-top: 10px; padding: 8px 10px; border-radius: 6px; background: var(--red-dim); border: 1px solid rgba(255,77,77,.2); font-size: 11px; color: var(--red); font-family: var(--ff-mono); }
  .ctx-status-label { font-size: 8px; letter-spacing: .08em; text-transform: uppercase; color: rgba(255,77,77,.6); margin-bottom: 3px; }

  .row-top { display: grid; grid-template-columns: 180px 1fr; gap: 10px; margin-bottom: 10px; }
  .score-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--r-lg); padding: 16px 12px; display: flex; flex-direction: column; align-items: center; justify-content: center; position: relative; overflow: hidden; }
  .score-card::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse at 50% 110%, var(--score-glow, var(--blue-glow)) 0%, transparent 70%); pointer-events: none; }
  .score-lbl { font-size: 8px; font-family: var(--ff-mono); color: var(--text-3); letter-spacing: .1em; text-transform: uppercase; margin-bottom: 10px; }
  .gauge-wrap { position: relative; width: 80px; height: 80px; margin-bottom: 8px; }
  .gauge-wrap svg { width: 100%; height: 100%; }
  .gauge-num { position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; }
  .gauge-num .sn-big { font-family: var(--ff-head); font-size: 30px; line-height: 1; color: var(--text); }
  .gauge-num .sn-den { font-size: 9px; color: var(--text-3); font-family: var(--ff-mono); }
  .classif-pill { padding: 3px 12px; border-radius: 100px; font-size: 9px; font-family: var(--ff-mono); font-weight: 600; letter-spacing: .06em; margin-bottom: 8px; }
  .classif-avancou { background: var(--green-dim); color: var(--green); border: 1px solid rgba(61,220,132,.25); }
  .classif-neutra { background: var(--amber-dim); color: var(--amber); border: 1px solid rgba(245,166,35,.25); }
  .classif-piorou { background: var(--red-dim); color: var(--red); border: 1px solid rgba(255,77,77,.25); }
  .score-risco { font-size: 10px; font-family: var(--ff-mono); color: var(--red); background: var(--red-dim); border: 1px solid rgba(255,77,77,.2); padding: 3px 8px; border-radius: 5px; text-align: center; }

  .insight-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--r-lg); padding: 20px; display: flex; flex-direction: column; justify-content: center; }
  .ins-tag { font-size: 8px; font-family: var(--ff-mono); color: var(--text-3); letter-spacing: .1em; text-transform: uppercase; margin-bottom: 10px; }
  .ins-text { font-size: 15px; font-style: italic; color: var(--text); line-height: 1.6; border-left: 3px solid var(--blue); padding-left: 14px; }

  .row-mid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 10px; }
  .sec-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--r-lg); padding: 16px; }
  .sec-lbl { font-size: 8px; font-family: var(--ff-mono); color: var(--text-3); letter-spacing: .1em; text-transform: uppercase; margin-bottom: 12px; padding-bottom: 8px; border-bottom: 1px solid var(--border); }

  .radar-wrap { width: 150px; height: 150px; margin: 0 auto 12px; }
  .radar-wrap svg { width: 100%; height: 100%; }
  .s-bars { display: flex; flex-direction: column; gap: 5px; }
  .s-row { display: flex; align-items: center; gap: 6px; }
  .s-key { font-size: 9px; font-family: var(--ff-mono); color: var(--text-3); width: 76px; flex-shrink: 0; }
  .s-track { flex: 1; height: 2px; background: rgba(255,255,255,.06); border-radius: 2px; }
  .s-fill { height: 100%; border-radius: 2px; transition: width .8s cubic-bezier(.4,0,.2,1); }
  .s-nota { font-size: 10px; font-family: var(--ff-mono); color: var(--text); width: 16px; text-align: right; flex-shrink: 0; }

  .bant-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 6px; }
  .bant-b { padding: 10px; border-radius: 8px; border: 1px solid var(--border); }
  .bant-ok { background: rgba(61,220,132,.04); border-color: rgba(61,220,132,.2); }
  .bant-no { background: rgba(255,77,77,.04); border-color: rgba(255,77,77,.2); }
  .bant-big { font-family: var(--ff-head); font-size: 22px; line-height: 1; margin-bottom: 2px; }
  .bant-ok .bant-big { color: var(--green); }
  .bant-no .bant-big { color: var(--red); }
  .bant-name { font-size: 9px; font-family: var(--ff-mono); color: var(--text-3); margin-bottom: 3px; }
  .bant-st { font-size: 9px; font-family: var(--ff-mono); font-weight: 600; letter-spacing: .04em; }
  .bant-ok .bant-st { color: var(--green); }
  .bant-no .bant-st { color: var(--red); }
  .bant-desc { font-size: 10px; color: var(--text-2); line-height: 1.4; margin-top: 4px; }
  .bant-impact { font-size: 9px; font-family: var(--ff-mono); color: var(--red); margin-top: 5px; padding-top: 5px; border-top: 1px solid rgba(255,77,77,.15); }
  .bant-impact-label { color: rgba(255,77,77,.5); margin-right: 4px; }

  .row-act { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 10px; }
  .erros-list { display: flex; flex-direction: column; gap: 6px; }
  .erro-item { padding: 10px 12px; border-radius: 8px; background: var(--red-dim); border: 1px solid rgba(255,77,77,.15); }
  .erro-hdr { display: flex; align-items: center; gap: 6px; margin-bottom: 4px; }
  .erro-rank { font-family: var(--ff-head); font-size: 16px; color: var(--red); opacity: .4; width: 18px; flex-shrink: 0; }
  .erro-titulo { font-size: 11px; font-weight: 500; color: var(--text); flex: 1; }
  .imp-badge { font-size: 8px; font-family: var(--ff-mono); padding: 2px 6px; border-radius: 4px; font-weight: 600; letter-spacing: .06em; }
  .imp-alto { background: rgba(255,77,77,.2); color: var(--red); }
  .imp-med { background: var(--amber-dim); color: var(--amber); }
  .imp-baixo { background: rgba(255,255,255,.06); color: var(--text-3); }
  .erro-det { font-size: 10px; color: var(--text-2); line-height: 1.4; padding-left: 24px; margin-bottom: 4px; }
  .erro-conseq { font-size: 9px; font-family: var(--ff-mono); color: var(--amber); padding-left: 24px; }
  .erro-conseq-label { color: rgba(245,166,35,.5); margin-right: 4px; }

  .pna-card { background: var(--blue); border-radius: var(--r-lg); padding: 20px; display: flex; flex-direction: column; }
  .pna-urgencia { font-size: 11px; color: rgba(255,255,255,.6); font-style: italic; margin-bottom: 12px; padding-bottom: 12px; border-bottom: 1px solid rgba(255,255,255,.15); }
  .pna-tag { font-size: 8px; font-family: var(--ff-mono); color: rgba(255,255,255,.5); letter-spacing: .1em; text-transform: uppercase; margin-bottom: 10px; }
  .pna-title { font-family: var(--ff-head); font-size: 18px; letter-spacing: .04em; color: #fff; margin-bottom: 10px; }
  .pna-txt { font-size: 12px; color: rgba(255,255,255,.85); line-height: 1.7; flex: 1; }
  .pna-dead { margin-top: 14px; padding-top: 14px; border-top: 1px solid rgba(255,255,255,.15); font-size: 9px; color: rgba(255,255,255,.4); font-family: var(--ff-mono); }

  .row-sup { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 10px; }
  .list-items { display: flex; flex-direction: column; gap: 5px; }
  .list-item { display: flex; align-items: flex-start; gap: 6px; padding: 8px 10px; border-radius: 7px; background: rgba(255,255,255,.02); border: 1px solid var(--border); font-size: 11px; color: var(--text-2); line-height: 1.4; }
  .list-dot { width: 4px; height: 4px; border-radius: 50%; flex-shrink: 0; margin-top: 4px; }
  .dot-g { background: var(--green); }
  .dot-b { background: var(--blue); }

  .diag-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--r-lg); padding: 16px; margin-bottom: 10px; }
  .diag-txt { font-size: 12px; color: var(--text-2); line-height: 1.8; }

  .scaleco-block { border: 1px solid rgba(45,91,227,.3); border-radius: var(--r-lg); padding: 20px; background: var(--blue-dim); margin-bottom: 10px; }
  .scaleco-intro { font-size: 12px; color: var(--text-2); line-height: 1.7; margin-bottom: 14px; }
  .scaleco-intro strong { color: var(--text); }
  .scaleco-cta { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
  .scaleco-cta-text { font-size: 13px; color: var(--text); font-weight: 500; }
  .scaleco-cta-link { padding: 7px 16px; background: var(--blue); color: #fff; border-radius: 8px; font-family: var(--ff-head); font-size: 13px; letter-spacing: .04em; text-decoration: none; white-space: nowrap; }

  .result-footer { display: flex; justify-content: space-between; align-items: center; padding-top: 14px; border-top: 1px solid var(--border); }
  .footer-note { font-size: 10px; color: var(--text-3); font-family: var(--ff-mono); }
  .footer-ip { font-size: 10px; color: var(--text-3); font-family: var(--ff-mono); }

  footer { margin-top: 50px; padding-top: 20px; border-top: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px; }
  .footer-brand { font-family: var(--ff-head); font-size: 14px; color: var(--text-2); letter-spacing: .04em; }
  .footer-brand span { color: var(--blue); }
  .footer-links { display: flex; gap: 20px; }
  .footer-links a { font-size: 11px; color: var(--text-3); text-decoration: none; font-family: var(--ff-mono); }
  .footer-links a:hover { color: var(--text-2); }

  @keyframes fadeUp { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
  @keyframes spin { to { transform: rotate(360deg); } }

  @media (max-width: 640px) {
    .row-top, .row-mid, .row-act, .row-sup, .ctx-exec { grid-template-columns: 1fr; }
    .features-grid { grid-template-columns: 1fr 1fr; }
    .form-row { grid-template-columns: 1fr; }
    .ctx-col+.ctx-col { border-left: none; border-top: 1px solid var(--border); }
  }
  @media (max-width: 400px) {
    .features-grid, .bant-grid { grid-template-columns: 1fr; }
  }
</style>
</head>
<body>
<div class="page">

  <header>
    <div class="hdr-title">CALL DIAGNOSIS™</div>
    <div class="hdr-by">by <span>ScaleCo</span></div>
  </header>

  <!-- FORM -->
  <section id="gateSection">
    <div class="gate-hero">
      <h2>Essa call não falhou<br>por execução.<br><span>Falhou por arquitetura.</span></h2>
      <p>Leitura estrutural da sua performance comercial com base no framework SCALE + qualificação BANT.</p>
    </div>

    <div class="features-grid">
      <div class="feat"><div class="feat-icon">▲</div><div class="feat-title">Erros críticos</div><div class="feat-desc">O que está custando conversão agora</div></div>
      <div class="feat"><div class="feat-icon">→</div><div class="feat-title">Próxima ação</div><div class="feat-desc">O que executar em até 24h</div></div>
      <div class="feat"><div class="feat-icon">◈</div><div class="feat-title">SCALE Score</div><div class="feat-desc">6 dimensões com nota e análise</div></div>
      <div class="feat"><div class="feat-icon">◎</div><div class="feat-title">BANT Audit</div><div class="feat-desc">Budget, Authority, Need, Timing</div></div>
    </div>

    <div class="form-row">
      <div class="form-group"><label>Seu nome</label><input type="text" id="gNome" placeholder="João Silva"></div>
      <div class="form-group"><label>E-mail</label><input type="email" id="gEmail" placeholder="joao@empresa.com.br"></div>
    </div>
    <div class="form-row">
      <div class="form-group"><label>Sua empresa</label><input type="text" id="gEmpresaLead" placeholder="Nome da empresa"></div>
      <div class="form-group"><label>Cargo</label><input type="text" id="gCargo" placeholder="CEO, Diretor Comercial..."></div>
    </div>

    <div class="divider">dados da call</div>

    <div class="form-row">
      <div class="form-group"><label>Empresa analisada</label><input type="text" id="empresa" placeholder="Ex: Alfaterm"></div>
      <div class="form-group"><label>Segmento</label><input type="text" id="segmento" placeholder="Ex: Manufatura B2B"></div>
    </div>
    <div class="form-row">
      <div class="form-group"><label>Ticket médio</label><input type="text" id="ticket" placeholder="Ex: R$ 70k/ano"></div>
      <div class="form-group">
        <label>Tipo de call</label>
        <select id="tipo">
          <option value="discovery">Discovery</option>
          <option value="prospeccao">Prospecção</option>
          <option value="fechamento">Fechamento</option>
        </select>
      </div>
    </div>
    <div class="form-group"><label>Transcrição da call</label><textarea id="transcricao" placeholder="Cole aqui a transcrição completa da call..."></textarea></div>

    <button class="btn-primary" id="analyzeBtn" onclick="runAnalysis()">
      <span>GERAR ANÁLISE DA CALL</span><span>→</span>
    </button>
    <div class="error-box" id="errorBox"></div>
  </section>

  <!-- LOADING -->
  <div id="loadingSection">
    <div class="loading-ring"></div>
    <div class="loading-title">PROCESSANDO</div>
    <div class="loading-msg" id="loadingMsg">Aplicando framework SCALE...</div>
  </div>

  <!-- RESULT -->
  <section id="resultSection">
    <div id="resultContent"></div>
    <div class="result-footer">
      <span class="footer-note" id="footerTs">Call Diagnosis™ · by ScaleCo</span>
      <button class="btn-ghost" onclick="resetForm()">← Analisar nova interação</button>
    </div>
  </section>

  <footer>
    <div class="footer-brand">Scale<span>Co</span> · Revenue Architecture™</div>
    <div class="footer-links">
      <a href="https://scaleco.ai" target="_blank">scaleco.ai</a>
      <a href="https://diagnostic.scaleco.ai" target="_blank">Scale Diagnostic™</a>
    </div>
  </footer>

</div>
<script>
const loadingMsgs = ['Aplicando framework SCALE...','Auditando qualificação BANT...','Identificando gaps estruturais...','Calculando scorecard final...','Gerando diagnóstico comercial...'];
let loadingInterval;

function showError(msg) { const b=document.getElementById('errorBox'); b.textContent=msg; b.classList.add('visible'); }
function hideError() { document.getElementById('errorBox').classList.remove('visible'); }

function startLoading() {
  document.getElementById('gateSection').style.display='none';
  document.getElementById('loadingSection').style.display='block';
  let i=0;
  document.getElementById('loadingMsg').textContent=loadingMsgs[0];
  loadingInterval=setInterval(()=>{ i=(i+1)%loadingMsgs.length; document.getElementById('loadingMsg').textContent=loadingMsgs[i]; },2000);
}
function stopLoading() { clearInterval(loadingInterval); document.getElementById('loadingSection').style.display='none'; }
function resetForm() { document.getElementById('resultSection').style.display='none'; document.getElementById('gateSection').style.display='block'; hideError(); }

function barColor(n) { return n<=3?'var(--red)':n<=6?'var(--amber)':'var(--green)'; }
function scoreGlow(n) { return n<=3?'rgba(255,77,77,0.25)':n<=6?'rgba(245,166,35,0.25)':'rgba(61,220,132,0.25)'; }
function scoreStroke(n) { return n<=3?'var(--red)':n<=6?'var(--amber)':'var(--green)'; }
function pillClass(c) { const v=(c||'').toUpperCase(); if(v.includes('AVAN'))return'classif-avancou'; if(v.includes('NEUTR'))return'classif-neutra'; return'classif-piorou'; }
function impactoClass(i) { const v=(i||'').toLowerCase(); if(v.includes('alt'))return'imp-alto'; if(v.includes('med'))return'imp-med'; return'imp-baixo'; }
function listHTML(arr,cls) {
  if(!arr||!arr.length) return '<div class="list-item"><div class="list-dot" style="background:#333"></div><span>Nenhum item identificado.</span></div>';
  return arr.map(t=>`<div class="list-item"><div class="list-dot ${cls}"></div><span>${t}</span></div>`).join('');
}

function gaugeHTML(score,color) {
  const r=42,circ=2*Math.PI*r,dash=(score/10)*circ,gap=circ-dash;
  return `<svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
    <circle cx="50" cy="50" r="${r}" fill="none" stroke="rgba(255,255,255,0.05)" stroke-width="6"/>
    <circle cx="50" cy="50" r="${r}" fill="none" stroke="${color}" stroke-width="6"
      stroke-dasharray="${dash} ${gap}" stroke-dashoffset="${circ*0.25}" stroke-linecap="round"/>
  </svg>`;
}

function radarHTML(scores) {
  const keys=['strategic','commercial','analytics','leadership','execution','governance'];
  const labels=['S','C','A','L','E','G'];
  const cx=100,cy=100,maxR=78,n=keys.length;
  const angle=i=>(i*2*Math.PI/n)-Math.PI/2;
  let grid='',axes='',labelsSvg='',dots='';
  for(let ring=1;ring<=5;ring++){
    const rr=(ring/5)*maxR;
    const pts=Array.from({length:n},(_,i)=>{const a=angle(i);return`${cx+rr*Math.cos(a)},${cy+rr*Math.sin(a)}`;}).join(' ');
    grid+=`<polygon points="${pts}" fill="none" stroke="rgba(255,255,255,0.05)" stroke-width="1"/>`;
  }
  for(let i=0;i<n;i++){const a=angle(i);axes+=`<line x1="${cx}" y1="${cy}" x2="${cx+maxR*Math.cos(a)}" y2="${cy+maxR*Math.sin(a)}" stroke="rgba(255,255,255,0.06)" stroke-width="1"/>`;}
  const pts=keys.map((k,i)=>{const v=((scores[k]?.nota||0)/10);const a=angle(i);return`${cx+v*maxR*Math.cos(a)},${cy+v*maxR*Math.sin(a)}`;}).join(' ');
  for(let i=0;i<n;i++){const a=angle(i);const lx=cx+(maxR+14)*Math.cos(a),ly=cy+(maxR+14)*Math.sin(a);labelsSvg+=`<text x="${lx}" y="${ly}" text-anchor="middle" dominant-baseline="middle" font-family="DM Mono,monospace" font-size="10" fill="rgba(255,255,255,0.3)">${labels[i]}</text>`;}
  keys.forEach((k,i)=>{const v=((scores[k]?.nota||0)/10);const a=angle(i);dots+=`<circle cx="${cx+v*maxR*Math.cos(a)}" cy="${cy+v*maxR*Math.sin(a)}" r="3" fill="#2D5BE3"/>`;});
  return`<svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">${grid}${axes}<polygon points="${pts}" fill="rgba(45,91,227,0.15)" stroke="#2D5BE3" stroke-width="1.5"/>${labelsSvg}${dots}</svg>`;
}

function renderResult(d) {
  const score=d.score_geral||0;
  const classif=(d.classificacao_call||'NEUTRA').toUpperCase();
  const scaleKeys=['strategic','commercial','analytics','leadership','execution','governance'];
  const scaleLabels={strategic:'Strategic',commercial:'Commercial',analytics:'Analytics',leadership:'Leadership',execution:'Execution',governance:'Governance'};
  const bantKeys=['budget','authority','need','timing'];
  const bantLabels={budget:'Budget',authority:'Authority',need:'Need',timing:'Timing'};
  const now=new Date();
  const ts=now.toLocaleDateString('pt-BR',{day:'2-digit',month:'long',year:'numeric'})+' · '+now.toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit'});
  const empresa=document.getElementById('empresa').value.trim()||'—';
  const segmento=document.getElementById('segmento').value.trim()||'—';
  const ticket=document.getElementById('ticket').value.trim()||'—';
  const tipo=document.getElementById('tipo').value||'discovery';
  const nome=document.getElementById('gNome').value.trim()||'—';

  const erros=(d.erros_criticos||[]).map((e,idx)=>{
    const titulo=typeof e==='object'?e.titulo:e;
    const impacto=typeof e==='object'?(e.impacto||'Alto'):'Alto';
    const detalhe=typeof e==='object'?(e.detalhe||''):'';
    const conseq=typeof e==='object'?(e.consequencia||''):'';
    return`<div class="erro-item">
      <div class="erro-hdr"><span class="erro-rank">${idx+1}</span><span class="erro-titulo">${titulo}</span><span class="imp-badge ${impactoClass(impacto)}">${impacto.toUpperCase()}</span></div>
      ${detalhe?`<div class="erro-det">${detalhe}</div>`:''}
      ${conseq?`<div class="erro-conseq"><span class="erro-conseq-label">Consequência:</span>${conseq}</div>`:''}
    </div>`;
  }).join('');

  const scaleBars=scaleKeys.map(k=>{const nota=(d.scale_score||{})[k]?.nota||0;return`<div class="s-row"><span class="s-key">${scaleLabels[k]}</span><div class="s-track"><div class="s-fill" style="width:${nota*10}%;background:${barColor(nota)}"></div></div><span class="s-nota">${nota}</span></div>`;}).join('');

  const bantBlocks=bantKeys.map(k=>{
    const b=(d.bant_score||{})[k]||{};const ok=b.coberto===true;
    return`<div class="bant-b ${ok?'bant-ok':'bant-no'}">
      <div class="bant-big">${k[0].toUpperCase()}</div>
      <div class="bant-name">${bantLabels[k]}</div>
      <div class="bant-st">${ok?'✓ COBERTO':'✗ AUSENTE'}</div>
      <div class="bant-desc">${b.analise||'—'}</div>
      ${!ok&&b.impacto?`<div class="bant-impact"><span class="bant-impact-label">Impacto:</span>${b.impacto}</div>`:''}
    </div>`;
  }).join('');

  // Status executivo — gerado a partir dos dados
  const bantAusentes=bantKeys.filter(k=>!(d.bant_score||{})[k]?.coberto);
  const statusMsg=bantAusentes.length>0
    ?`Deal em risco — ${bantAusentes.map(k=>({budget:'Budget',authority:'Authority',need:'Need',timing:'Timing'})[k]).join(', ')} não coberto${bantAusentes.length>1?'s':''}`
    :'Qualificação completa — deal bem posicionado';
  const statusIsRisk=bantAusentes.length>0;

  document.getElementById('resultContent').innerHTML=`
    <div class="ctx-exec">
      <div class="ctx-col">
        <div class="ctx-col-label">Call analisada</div>
        <div class="ctx-deal-title">${empresa}</div>
        <div class="ctx-deal-sub">${tipo.charAt(0).toUpperCase()+tipo.slice(1)} Call · ${ts}</div>
        <div class="ctx-status" style="${!statusIsRisk?'background:var(--green-dim);border-color:rgba(61,220,132,.2);color:var(--green)':''}">
          <div class="ctx-status-label" style="${!statusIsRisk?'color:rgba(61,220,132,.6)':''}">Status do deal</div>
          ${statusMsg}
        </div>
      </div>
      <div class="ctx-col">
        <div class="ctx-col-label">Contexto</div>
        <div class="ctx-meta-row">
          <div class="ctx-meta-item"><strong>Ticket médio:</strong> ${ticket}</div>
          <div class="ctx-meta-item"><strong>Segmento:</strong> ${segmento}</div>
          <div class="ctx-meta-item"><strong>Tipo:</strong> ${tipo.charAt(0).toUpperCase()+tipo.slice(1)}</div>
          <div class="ctx-meta-item"><strong>Vendedor:</strong> ${nome}</div>
        </div>
      </div>
    </div>

    <div class="row-top">
      <div class="score-card" style="--score-glow:${scoreGlow(score)}">
        <div class="score-lbl">Score geral</div>
        <div class="gauge-wrap">
          ${gaugeHTML(score,scoreStroke(score))}
          <div class="gauge-num"><span class="sn-big">${score}</span><span class="sn-den">/10</span></div>
        </div>
        <span class="classif-pill ${pillClass(classif)}">${classif}</span>
        <div class="score-risco">Risco de não conversão: ${score>=8?'BAIXO':score>=6?'MÉDIO':'ALTO'}</div>
      </div>
      <div class="insight-card">
        <div class="ins-tag">Insight final</div>
        <div class="ins-text">${d.insight_final||'—'}</div>
      </div>
    </div>

    <div class="row-mid">
      <div class="sec-card">
        <div class="sec-lbl">SCALE Score</div>
        <div class="radar-wrap">${radarHTML(d.scale_score||{})}</div>
        <div class="s-bars">${scaleBars}</div>
      </div>
      <div class="sec-card">
        <div class="sec-lbl">Qualificação BANT</div>
        <div class="bant-grid">${bantBlocks}</div>
      </div>
    </div>

    <div class="row-act">
      <div class="sec-card">
        <div class="sec-lbl">Erros críticos</div>
        <div class="erros-list">${erros||'<div class="list-item"><div class="list-dot" style="background:#333"></div><span>Nenhum erro crítico identificado.</span></div>'}</div>
      </div>
      <div class="pna-card">
        <div class="pna-urgencia">Se você não fizer isso, o deal esfria.</div>
        <div class="pna-tag">Próxima melhor ação</div>
        <div class="pna-title">EXECUTE ISSO AGORA</div>
        <div class="pna-txt">${d.proxima_melhor_acao||'—'}</div>
        <div class="pna-dead">▸ Janela ideal: até 24h após a call</div>
      </div>
    </div>

    <div class="row-sup">
      <div class="sec-card">
        <div class="sec-lbl">Pontos fortes</div>
        <div class="list-items">${listHTML(d.pontos_fortes,'dot-g')}</div>
      </div>
      <div class="sec-card">
        <div class="sec-lbl">Perguntas que faltaram</div>
        <div class="list-items">${listHTML(d.perguntas_que_faltaram,'dot-b')}</div>
      </div>
    </div>

    <div class="diag-card">
      <div class="sec-lbl">Diagnóstico estrutural</div>
      <div class="diag-txt">${d.diagnostico_estrutural||'—'}</div>
    </div>

    <div class="scaleco-block">
      <div class="scaleco-intro">
        <strong>Essa análise mostra um padrão — não um evento isolado.</strong><br><br>
        Se esse tipo de call se repete, o problema não está no vendedor. Está na arquitetura comercial — ausência de processo de multi-thread, falta de protocolo de qualificação de decisor, pipeline sem governança.<br><br>
        É exatamente isso que a ScaleCo resolve.
      </div>
      <div class="scaleco-cta">
        <div class="scaleco-cta-text">Quer entender o padrão por trás dos seus deals?</div>
        <a class="scaleco-cta-link" href="https://wa.me/5511974270077" target="_blank">FALAR COM FÁBIO →</a>
      </div>
    </div>
  `;

  document.getElementById('footerTs').textContent=`Call Diagnosis™ · Gerado em ${ts}`;
  document.getElementById('resultSection').style.display='block';
  window.scrollTo({top:0,behavior:'smooth'});
}

async function runAnalysis() {
  hideError();
  const nome=document.getElementById('gNome').value.trim();
  const email=document.getElementById('gEmail').value.trim();
  const empresaLead=document.getElementById('gEmpresaLead').value.trim();
  const transcricao=document.getElementById('transcricao').value.trim();
  if(!nome){showError('Informe seu nome.');return;}
  if(!email||!email.includes('@')){showError('Informe um e-mail válido.');return;}
  if(!empresaLead){showError('Informe o nome da sua empresa.');return;}
  if(!transcricao||transcricao.length<80){showError('A transcrição parece muito curta. Cole o texto completo da call.');return;}
  startLoading();
  try {
    const resp=await fetch('/.netlify/functions/analyze-call',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({
        nome,email,
        empresaLead,cargo:document.getElementById('gCargo').value.trim(),
        empresa:document.getElementById('empresa').value.trim(),
        segmento:document.getElementById('segmento').value.trim(),
        ticket:document.getElementById('ticket').value.trim(),
        tipo:document.getElementById('tipo').value,
        transcricao
      })
    });
    const data=await resp.json();
    if(!resp.ok) throw new Error(data.error||`HTTP ${resp.status}`);
    stopLoading();
    renderResult(data);
  } catch(e) {
    stopLoading();
    document.getElementById('gateSection').style.display='block';
    showError('Erro na análise: '+e.message);
  }
}
</script>
</body>
</html>
